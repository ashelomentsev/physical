def build_remote_payload(code: str, port: int) -> str:
    payload = {"type": "execute_script", "params": {"code": code}}
    return textwrap.dedent(
        f"""
        import json
        import socket
        import sys

        payload = {json.dumps(payload)}
        sock = socket.socket()
        sock.settimeout(120)
        sock.connect(("127.0.0.1", {port}))
        sock.sendall(json.dumps(payload).encode())
        data = b""
        while True:
            chunk = sock.recv(65536)
            if not chunk:
                break
            data += chunk
            try:
                obj = json.loads(data.decode())
                print(json.dumps(obj))
                break
            except Exception:
                pass
        sock.close()
        """
    ).strip() + "\n"


def run_remote_python(script: str, host: str, user: str, key_path: Path) -> dict:
    cmd = ["ssh", "-i", str(key_path), f"{user}@{host}", "python3", "-"]
    completed = subprocess.run(cmd, input=script, text=True, capture_output=True)
    if completed.returncode != 0:
        raise RuntimeError(completed.stderr.strip() or completed.stdout.strip() or "remote command failed")
    stdout = completed.stdout.strip()
    if not stdout:
        raise RuntimeError("remote command returned no output")
    return json.loads(stdout)


def execute_script(code: str, host: str, user: str, key_path: Path, port: int) -> dict:
    remote = build_remote_payload(code, port)
    response = run_remote_python(remote, host, user, key_path)
    if response.get("status") != "success":
        raise RuntimeError(response.get("message", "socket command failed"))
    inner = response.get("result", {})
    if inner.get("status") != "success":
        raise RuntimeError(inner.get("message", "execute_script failed"))
    return inner.get("result")


def build_command_code(command: str, args: argparse.Namespace) -> str:
    command_expr = {
        "status": "result = robotctl_status()",
        "reset": "result = robotctl_reset()",
        "stop": "result = robotctl_stop()",
        "walk": f"result = robotctl_walk(speed={args.speed!r})",
        "turn-around": "result = robotctl_turn_around()",
        "velocity": f"result = robotctl_velocity(vx={args.vx!r}, vy={args.vy!r}, wz={args.wz!r})",
    }[command]
    return HELPER_CODE + "\nrobotctl_install()\n" + command_expr + "\n"


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Simple terminal control for the Isaac Sim robot.")
    parser.add_argument("--host", default=DEFAULT_HOST, help="VM host running Isaac Sim")
    parser.add_argument("--user", default=DEFAULT_USER, help="SSH user for the VM")
    parser.add_argument("--key", default=str(Path(__file__).resolve().with_name("id_ed25519")), help="SSH private key path")
    parser.add_argument("--port", type=int, default=DEFAULT_PORT, help="Local Isaac MCP socket port on the VM")

    subparsers = parser.add_subparsers(dest="command", required=True)

    subparsers.add_parser("status", help="Show current robot/controller status")
    subparsers.add_parser("reset", help="Reset robot to an initial upright pose south of the box gap")
    subparsers.add_parser("stop", help="Stop motion and hold current upright pose")

    walk_parser = subparsers.add_parser("walk", help="Start walking forward with the given speed")
    walk_parser.add_argument("--speed", type=float, default=0.25, help="Forward speed in m/s")

    subparsers.add_parser("turn-around", help="Turn the robot 180 degrees in place")

    velocity_parser = subparsers.add_parser("velocity", help="Set direct velocity command")
    velocity_parser.add_argument("--vx", type=float, default=0.25, help="Forward velocity in m/s")
    velocity_parser.add_argument("--vy", type=float, default=0.0, help="Sideways velocity in m/s")
    velocity_parser.add_argument("--wz", type=float, default=0.0, help="Yaw rate in rad/s")

    return parser.parse_args()


def main() -> int:
    args = parse_args()
    key_path = Path(args.key).expanduser().resolve()
    if not key_path.exists():
        print(f"SSH key not found: {key_path}", file=sys.stderr)
        return 1

    try:
        result = execute_script(
            build_command_code(args.command, args),
            host=args.host,
            user=args.user,
            key_path=key_path,
            port=args.port,
        )
    except Exception as exc:
        print(f"robotctl error: {exc}", file=sys.stderr)
        return 1

    print(json.dumps(result, indent=2))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
